{% extends '@NowoTaskBoardBundle/layout.html.twig' %}

{% block title %}{{ 'task_board.import.title'|trans({}, 'NowoTaskBoardBundle') }} — {{ board.name }}{% endblock %}

{% block body %}
    {% include '@NowoTaskBoardBundle/manage/_page_header.html.twig' with {
        pageTitle: 'task_board.import.title'|trans({}, 'NowoTaskBoardBundle'),
        pageSubtitle: 'task_board.import.subtitle'|trans({}, 'NowoTaskBoardBundle'),
        breadcrumbRoute: 'nowo_task_board_board',
        breadcrumbRouteParams: { boardId: board.id },
        breadcrumbParams: { boardId: board.id },
        breadcrumbLabel: board.name,
        headerActions: '
            <a href="' ~ path('nowo_task_board_board', { boardId: board.id }) ~ '" class="btn btn-outline-secondary">
                <i class="ti ti-arrow-left"></i> ' ~ ('task_board.view.back_board'|trans({}, 'NowoTaskBoardBundle')) ~ '
            </a>
        ',
        dashboardRoute: dashboardRoute|default(null),
    } %}

    {% include '@NowoTaskBoardBundle/manage/_flashes.html.twig' %}

    <div class="row row-cards">
        <div class="col-12 col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">{{ 'task_board.import.form.title'|trans({}, 'NowoTaskBoardBundle') }}</h2>
                </div>
                <div class="card-body">
                    {{ form_start(importForm, {
                        action: path('nowo_task_board_board_import', { boardId: board.id }),
                        method: 'POST',
                        attr: { enctype: 'multipart/form-data' }
                    }) }}
                        {{ form_row(importForm.source) }}
                        {{ form_row(importForm.file) }}
                        {{ form_row(importForm.createMissingColumns) }}
                        {{ form_row(importForm.skipExisting) }}
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-upload me-1"></i>{{ 'task_board.import.form.submit'|trans({}, 'NowoTaskBoardBundle') }}
                        </button>
                    {{ form_end(importForm) }}
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">{{ 'task_board.import.help.title'|trans({}, 'NowoTaskBoardBundle') }}</h3>
                </div>
                <div class="card-body">
                    <h4 class="h5">{{ 'task_board.import.help.clickup_title'|trans({}, 'NowoTaskBoardBundle') }}</h4>
                    <ol class="text-secondary small mb-4">
                        <li>{{ 'task_board.import.help.clickup_step_1'|trans({}, 'NowoTaskBoardBundle') }}</li>
                        <li>{{ 'task_board.import.help.clickup_step_2'|trans({}, 'NowoTaskBoardBundle') }}</li>
                        <li>{{ 'task_board.import.help.clickup_step_3'|trans({}, 'NowoTaskBoardBundle') }}</li>
                    </ol>
                    <h4 class="h5">{{ 'task_board.import.help.supported_title'|trans({}, 'NowoTaskBoardBundle') }}</h4>
                    <ul class="text-secondary small mb-0">
                        <li>{{ 'task_board.import.source.clickup_csv'|trans({}, 'NowoTaskBoardBundle') }}</li>
                        <li>{{ 'task_board.import.source.clickup_json'|trans({}, 'NowoTaskBoardBundle') }}</li>
                        <li>{{ 'task_board.import.source.jira_csv'|trans({}, 'NowoTaskBoardBundle') }}</li>
                        <li>{{ 'task_board.import.source.trello_json'|trans({}, 'NowoTaskBoardBundle') }}</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
