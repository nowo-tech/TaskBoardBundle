<div class="page-header d-print-none mb-4">
    <div class="row align-items-center">
        <div class="col">
            {% if breadcrumbRoute|default(null) and breadcrumbLabel|default(null) %}
                <div class="text-secondary small mb-1">
                    <a href="{{ path(breadcrumbRoute, breadcrumbParams|default({})) }}" class="text-reset">{{ breadcrumbLabel }}</a>
                </div>
            {% endif %}
            <h1 class="page-title">{{ pageTitle }}</h1>
            {% if pageSubtitle|default(null) %}
                <p class="text-secondary mb-0">{{ pageSubtitle }}</p>
            {% endif %}
        </div>
        <div class="col-auto d-flex gap-2 flex-wrap">
            {% if headerActions is defined %}
                {{ headerActions|raw }}
            {% endif %}
            {% if dashboardRoute|default(null) %}
                <a href="{{ path(dashboardRoute) }}" class="btn btn-outline-secondary">{{ 'task_board.action.back'|trans({}, 'NowoTaskBoardBundle') }}</a>
            {% endif %}
        </div>
    </div>
</div>
