<div
    class="modal modal-blur fade"
    data-nowo-task-board-task-links-modal-target="modal"
    tabindex="-1"
    role="dialog"
    aria-hidden="true"
    aria-labelledby="nowo-task-board-task-links-modal-title"
>
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="nowo-task-board-task-links-modal-title" data-nowo-task-board-task-links-modal-target="title">
                    {{ 'task_board.task.links_modal_add_title'|trans({}, 'NowoTaskBoardBundle') }}
                </h5>
                <button type="button" class="btn-close" aria-label="{{ 'task_board.action.close'|trans({}, 'NowoTaskBoardBundle') }}" data-action="click->nowo-task-board-task-links-modal#close"></button>
            </div>
            {{ form_start(linkForm, {
                action: path('nowo_task_board_task_link', { taskId: task.id }),
                method: 'POST',
                attr: {
                    id: 'nowo-task-link-form',
                    'data-nowo-task-board-task-links-modal-target': 'form',
                },
            }) }}
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">{{ form_row(linkForm.linkType, { attr: { 'data-nowo-task-board-task-links-modal-target': 'linkType' } }) }}</div>
                        <div class="col-md-8">{{ form_row(linkForm.url, { attr: { 'data-nowo-task-board-task-links-modal-target': 'url' } }) }}</div>
                        <div class="col-md-6">{{ form_row(linkForm.label, { attr: { 'data-nowo-task-board-task-links-modal-target': 'label' } }) }}</div>
                        <div class="col-md-6">{{ form_row(linkForm.externalId, { attr: { 'data-nowo-task-board-task-links-modal-target': 'externalId' } }) }}</div>
                    </div>
                </div>
                <div class="modal-footer justify-content-between">
                    <div>
                        <button
                            type="submit"
                            form="nowo-task-link-delete-form"
                            class="btn btn-outline-danger d-none"
                            data-nowo-task-board-task-links-modal-target="deleteButton"
                            onclick="return confirm('{{ 'task_board.task.link_delete_confirm'|trans({}, 'NowoTaskBoardBundle')|e('js') }}')"
                        >
                            <i class="ti ti-trash me-1"></i>{{ 'task_board.action.remove_link'|trans({}, 'NowoTaskBoardBundle') }}
                        </button>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-action="click->nowo-task-board-task-links-modal#close">
                            {{ 'task_board.action.cancel'|trans({}, 'NowoTaskBoardBundle') }}
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy me-1"></i>{{ 'task_board.action.save'|trans({}, 'NowoTaskBoardBundle') }}
                        </button>
                    </div>
                </div>
            {{ form_end(linkForm) }}
            <form
                id="nowo-task-link-delete-form"
                method="post"
                action="#"
                class="d-none"
                data-nowo-task-board-task-links-modal-target="deleteForm"
            ></form>
        </div>
    </div>
</div>
<div
    class="modal-backdrop fade"
    data-nowo-task-board-task-links-modal-target="backdrop"
    data-action="click->nowo-task-board-task-links-modal#closeOnBackdrop"
></div>
