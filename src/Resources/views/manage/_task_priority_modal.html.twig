{% import '@NowoTaskBoardBundle/manage/_task_priority_tag.html.twig' as priorityUi %}

<div
    class="modal modal-blur fade"
    data-nowo-task-board-task-priority-modal-target="modal"
    tabindex="-1"
    role="dialog"
    aria-hidden="true"
    aria-labelledby="nowo-task-board-task-priority-modal-title"
>
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="nowo-task-board-task-priority-modal-title">
                    {{ 'task_board.task.priority_modal_title'|trans({}, 'NowoTaskBoardBundle') }}
                </h5>
                <button type="button" class="btn-close" aria-label="{{ 'task_board.action.close'|trans({}, 'NowoTaskBoardBundle') }}" data-action="click->nowo-task-board-task-priority-modal#close"></button>
            </div>
            <form method="post" action="{{ path('nowo_task_board_task_priority', { taskId: task.id }) }}">
                <div class="modal-body">
                    <p class="text-secondary small mb-3">{{ 'task_board.task.priority_modal_help'|trans({}, 'NowoTaskBoardBundle') }}</p>
                    <div class="nowo-task-detail__priority-options">
                        {% for priority in priorities %}
                            <label class="nowo-task-detail__priority-option{% if task.priority == priority %} is-selected{% endif %}">
                                <input
                                    type="radio"
                                    name="priority"
                                    value="{{ priority.value }}"
                                    class="form-check-input"
                                    {% if task.priority == priority %}checked{% endif %}
                                    {% if loop.first %}data-nowo-task-board-task-priority-modal-target="firstOption"{% endif %}
                                >
                                <span class="nowo-task-detail__priority-option-content">
                                    {{ priorityUi.priority_tag(priority, false) }}
                                </span>
                            </label>
                        {% endfor %}
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-action="click->nowo-task-board-task-priority-modal#close">
                        {{ 'task_board.action.cancel'|trans({}, 'NowoTaskBoardBundle') }}
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="ti ti-device-floppy me-1"></i>{{ 'task_board.action.save'|trans({}, 'NowoTaskBoardBundle') }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<div
    class="modal-backdrop fade"
    data-nowo-task-board-task-priority-modal-target="backdrop"
    data-action="click->nowo-task-board-task-priority-modal#closeOnBackdrop"
></div>
